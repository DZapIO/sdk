{
  "name": "@dzapio/sdk",
  "version": "3.0.0",
  "description": "A TypeScript/JavaScript SDK for interacting with the DZap protocol, providing utilities for DeFi operations including Swaps, Bridges, and Zaps.",
  "main": "dist/index.js",
  "source": "src/index.ts",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node .",
    "dev:debug": "ts-node-dev --respawn --pretty --transpile-only ./src/index.ts",
    "yalcPublish": "npm run build && yalc publish",
    "pack": "yarn build && npm pack",
    "githubPublish": "npm run build && npm publish",
    "npmPublish": "npm run build && npm publish --access public",
    "build": "tsup",
    "dev": "nodemon",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint --fix src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "pretty": "prettier --write --ignore-unknown src/**/*.ts",
    "prepush": "npm run build",
    "prepare": "husky install && yarn run fix-permissions",
    "fix-permissions": "node ./scripts/fixPermissions.js"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npx lint-staged",
      "pre-push": "yarn prepush"
    }
  },
  "lint-staged": {
    "src/**/*.{js,ts}": "eslint --cache --fix",
    "src/**/*.{js,ts,md}": "prettier --write --ignore-unknown"
  },
  "keywords": [
    "DZap",
    "defi",
    "dex",
    "swap",
    "bridge",
    "zap",
    "dca",
    "ethereum",
    "blockchain",
    "web3",
    "typescript",
    "sdk",
    "dzapsdk",
    "dzap",
    "dzapio",
    "dzapio-sdk",
    "dzapio-sdk-js",
    "dzapio-sdk-ts",
    "dzapio-sdk-typescript",
    "dzapio-sdk-javascript",
    "dzapio-sdk-nodejs",
    "dzapio-sdk-react"
  ],
  "author": "DZap",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.7",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^48.10.0",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "husky": "^9.0.10",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.2",
    "tsup": "^8.3.5",
    "nodemon": "^2.0.16",
    "prettier": "^3.1.0",
    "ts-jest": "^29.4.0",
    "typedoc": "^0.26.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@bigmi/client": "^0.6.5",
    "@bigmi/core": "^0.6.5",
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@mempool/mempool.js": "^3.0.0",
    "@mysten/sui": "1.29.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.2.1",
    "bitcoinHelpers": "link:@xlink-network/xlink-sdk/bitcoinHelpers",
    "bitcoinjs-lib": "^7.0.1",
    "bs58": "^6.0.0",
    "decimal.js": "^10.4.3",
    "ethers": "5.7.2",
    "node-cache": "^5.1.2",
    "viem": "2.45.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dzapio/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/dzapio/sdk/issues"
  },
  "homepage": "https://github.com/dzapio/sdk#readme"
}
